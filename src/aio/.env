AIOPS_QUALIFICATION_GATE_DEV=false
AIOPS_QUALIFICATION_SCHEMA_PATH=config/signal_qualification_schema.json
AIOPS_NORMALIZATION_SCHEMA_PATH=config/signal_normalization_schema.json
AIOPS_QUALIFICATION_MAX_SAMPLE_AGE_SECONDS=300
AIOPS_AUTO_RUN_ENABLED=true
AIOPS_AUTO_RUN_INTERVAL_SECONDS=5
AIOPS_PROMETHEUS_BASE_URL=http://localhost:9090
AIOPS_PROMETHEUS_TIMEOUT_SECONDS=30
AIOPS_PROMETHEUS_TOKEN=
AIOPS_PROMETHEUS_ACCOUNT=prometheus-local
AIOPS_GRAFANA_WEBHOOK_SECRET=aiops-grafana-test-secret
AIOPS_JAEGER_BASE_URL=http://localhost:16686/jaeger/ui
AIOPS_JAEGER_TOKEN=
AIOPS_JAEGER_ACCOUNT=jaeger-local
AIOPS_OPENSEARCH_BASE_URL=https://localhost:9200
AIOPS_OPENSEARCH_USERNAME=admin
AIOPS_OPENSEARCH_PASSWORD=CHANGE_ME_OPENSEARCH_PASSWORD
AIOPS_OPENSEARCH_ACCOUNT=opensearch-local
AIOPS_OPENSEARCH_VERIFY_TLS=false
AIOPS_KUBERNETES_API_URL=https://kubernetes.default.svc
AIOPS_KUBERNETES_BEARER_TOKEN=CHANGE_ME_KUBERNETES_TOKEN
AIOPS_KUBERNETES_ACCOUNT=CHANGE_ME_KUBERNETES_SERVICE_ACCOUNT

AIOPS_NOTIFICATION_WEBHOOK_URL=https://notification.example
AIOPS_NOTIFICATION_TOKEN=
AIOPS_NOTIFICATION_ACCOUNT=
AIOPS_NOTIFICATION_PROVIDER=grafana

AIOPS_AIE_STATUS_URL=https://aie.example
AIOPS_AIE_TOKEN=CHANGE_ME_AIE_TOKEN
AIOPS_AIE_ACCOUNT=CHANGE_ME_AIE_ACCOUNT
AIOPS_CDO_COST_URL=https://cost.example
AIOPS_CDO_COST_TOKEN=CHANGE_ME_CDO_COST_TOKEN
AIOPS_CDO_COST_ACCOUNT=CHANGE_ME_CDO_COST_ACCOUNT
AIOPS_LIVE_EXECUTOR_URL=https://live-executor.example
AIOPS_LIVE_EXECUTOR_TOKEN=CHANGE_ME_LIVE_EXECUTOR_TOKEN
AIOPS_LIVE_EXECUTOR_ACCOUNT=CHANGE_ME_LIVE_EXECUTOR_ACCOUNT
