{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tf2:aiops:action-policy:1",
  "title": "AIOps action policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "runtime_mode", "blocked", "recommendations", "live_actions"],
  "properties": {
    "schema_version": {"type": "string"},
    "runtime_mode": {"const": "dry-run"},
    "blocked": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "recommendations": {"type": "array", "items": {"type": "object"}},
    "live_actions": {"type": "array", "maxItems": 0}
  }
}

