{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tf2:aiops:detector-definition:1",
  "title": "AIOps detector definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["detector_id", "type", "enabled", "signal_refs", "runbook_ref", "recovery", "evidence_ref"],
  "properties": {
    "detector_id": {"type": "string", "minLength": 1},
    "type": {"type": "string", "enum": ["official-slo", "no-data", "dependency", "saturation", "robust-anomaly", "signature", "kafka-lag", "llm-visibility"]},
    "enabled": {"type": "boolean"},
    "signal_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "runbook_ref": {"type": "string", "minLength": 1},
    "recovery": {"type": "object"},
    "evidence_ref": {"type": "string", "minLength": 1}
  }
}

