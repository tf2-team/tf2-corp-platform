{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tf2:aiops:signal-definition:1",
  "title": "AIOps signal definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["signal_id", "owner", "source_adapter", "query_ref", "unit", "shape", "cadence", "window", "freshness_limit", "qualification_state", "evidence_ref", "purpose"],
  "properties": {
    "signal_id": {"type": "string", "minLength": 1},
    "owner": {"type": "string", "minLength": 1},
    "source_adapter": {"type": "string", "enum": ["prometheus", "grafana", "jaeger", "opensearch", "kubernetes", "aie-status", "cost-status"]},
    "query_ref": {"type": "string", "minLength": 1},
    "unit": {"type": "string", "minLength": 1},
    "shape": {"type": "string", "enum": ["scalar", "vector", "matrix", "event"]},
    "cadence": {"type": "string", "minLength": 1},
    "window": {"type": "string", "minLength": 1},
    "freshness_limit": {"type": "string", "minLength": 1},
    "qualification_state": {"type": "string", "enum": ["unqualified", "verified", "fallback-only", "missing", "stale", "invalid"]},
    "evidence_ref": {"type": "string", "minLength": 1},
    "purpose": {"type": "string", "enum": ["official-sli", "diagnostic", "fallback"]},
    "required_labels": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "max_cardinality": {"type": "integer", "minimum": 1},
    "minimum_samples": {"type": "integer", "minimum": 0}
  }
}

