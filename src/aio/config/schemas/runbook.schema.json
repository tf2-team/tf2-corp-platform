{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tf2:aiops:runbook-front-matter:1",
  "title": "AIOps runbook front matter",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "runbook_id",
    "version",
    "title",
    "severity",
    "owner",
    "escalation",
    "flows",
    "services",
    "detector_types",
    "signal_refs",
    "allowed_runtime_mode",
    "evidence_required",
    "prohibited_actions",
    "verification",
    "communication_template"
  ],
  "properties": {
    "runbook_id": {"type": "string", "pattern": "^RB-[A-Z0-9-]+$"},
    "version": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "severity": {"type": "string", "enum": ["P0"]},
    "owner": {"type": "string", "minLength": 1},
    "escalation": {"type": "string", "minLength": 1},
    "flows": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "services": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "detector_types": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "signal_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "allowed_runtime_mode": {"type": "string", "enum": ["dry-run"]},
    "evidence_required": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "prohibited_actions": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "verification": {
      "type": "object",
      "required": ["signal_refs", "consecutive_cycles"],
      "properties": {
        "signal_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "consecutive_cycles": {"type": "integer", "minimum": 1}
      }
    },
    "communication_template": {"type": "string", "minLength": 1}
  }
}
