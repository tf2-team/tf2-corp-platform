{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tf2:aiops:runbook-index:1",
  "title": "AIOps runbook index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "runbooks"],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "runbooks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["runbook_id", "path", "priority", "matches", "sample_incident"],
        "properties": {
          "runbook_id": {"type": "string", "pattern": "^RB-[A-Z0-9-]+$"},
          "path": {"type": "string", "pattern": "^runbooks/.+\\.md$"},
          "priority": {"type": "integer", "minimum": 1},
          "matches": {
            "type": "object",
            "required": ["detector_ids", "detector_types", "flows", "services", "signal_ids"],
            "properties": {
              "detector_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
              "detector_types": {"type": "array", "items": {"type": "string"}, "minItems": 1},
              "flows": {"type": "array", "items": {"type": "string"}, "minItems": 1},
              "services": {"type": "array", "items": {"type": "string"}, "minItems": 1},
              "signal_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1}
            }
          },
          "sample_incident": {
            "type": "object",
            "required": ["incident_id", "detector_id", "detector_type", "flow", "service", "signal_id", "severity", "runbook_id"]
          }
        }
      }
    }
  }
}
