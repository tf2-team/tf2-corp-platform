{
  "rca": {
    "enabled": true,
    "top_k": 5,
    "min_points": 30,
    "ewma_alpha": 0.3,
    "ewma_z_threshold": 3.0,
    "seasonal_period": 1,
    "isolation_score_threshold": 4.0,
    "anomaly": {
      "algorithm_weights": {
        "ewma_stl": 0.8,
        "isolation_forest": 0.2
      },
      "weighted_score_threshold": 0.4,
      "single_algorithm_min_normalized_score": 2.0,
      "drain3_config_path": "config/drain3.ini",
      "log_bucket_seconds": 60,
      "log_correlation_window_seconds": 300,
      "log_history_buckets": 60,
      "log_min_nonzero_buckets": 2,
      "log_max_templates_per_service": 20,
      "log_max_events_per_evidence": 100
    },
    "graph": {
      "damping": 0.85,
      "pagerank_weight": 0.7,
      "timestamp_weight": 0.3
    },
    "combined": {
      "rrf_k": 20,
      "ranker_weights": {
        "graph": 0.3,
        "robust": 0.1,
        "earliest_drift": 0.4,
        "correlation": 0.2
      }
    }
  },
  "remediation": {
    "history_top_k": 3,
    "ood_threshold": 0.2,
    "cost_page": 20.0,
    "blast_radius_limit": 3,
    "confidence_threshold": 0.7,
    "similarity_weights": {
      "service": 0.35,
      "log": 0.25,
      "trace": 0.2,
      "metric": 0.2
    }
  },
  "no_data": {
    "missing_confidence": 1.0,
    "unknown_confidence": 0.7
  },
  "detectors": {
    "thresholds": {
      "ops01_checkout_slo": 0.01,
      "ops03_checkout_payment_dependency": 0.05,
      "auto_checkout_error_rate": 0.05,
      "auto_payment_error_rate": 0.05,
      "auto_frontend_proxy_error_rate": 0.05,
      "auto_frontend_error_rate": 0.05,
      "auto_product_catalog_error_rate": 0.05,
      "auto_product_reviews_error_rate": 0.05,
      "auto_recommendation_error_rate": 0.05,
      "auto_cart_error_rate": 0.005,
      "auto_ad_error_rate": 0.05,
      "auto_currency_error_rate": 0.05,
      "auto_shipping_error_rate": 0.05,
      "auto_email_error_rate": 0.05,
      "auto_quote_error_rate": 0.05,
      "auto_fraud_detection_error_rate": 0.05,
      "ops04_checkout_latency_p95": 0.5,
      "ops05_cart_error_rate": 0.02,
      "ops06_product_catalog_cpu": 50.0
    },
    "confidences": {
      "ops03_checkout_payment_dependency": 0.8
    }
  },
  "prometheus": {
    "metric_series": {
      "lookback_seconds": 6200,
      "step_seconds": 60
    }
  },
  "correlation": {
    "window_seconds": 300,
    "confidence_threshold": 0.5,
    "weights": {
      "verified_primary_signal": 0.25,
      "temporal_precedence": 0.2,
      "topology_path": 0.25,
      "operation_specificity": 0.1,
      "trace_log_kubernetes_corroboration": 0.2,
      "stale_or_missing_evidence_penalty": -0.3
    }
  }
}
