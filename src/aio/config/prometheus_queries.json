      "template_id": "dependency.grpc_client.error_ratio",
      "service": "checkout",
      "parameters": {"dependency": "payment", "dependency_id": "payment"},
      "labels": {"dependency": "payment"}
    },
    {
      "query_id": "postgresql.active_connections",
      "signal_id": "postgresql_active_connections",
      "template_id": "postgres.active_connections",
      "service": "postgresql"
    },
    {
      "query_id": "product_catalog.db_pool_utilization",
      "signal_id": "product_catalog_db_pool_utilization",
      "template_id": "postgres.client_pool_utilization",
      "service": "product-catalog"
    },
    {
      "query_id": "kafka.consumer_lag",
      "signal_id": "kafka_consumer_lag",
      "template_id": "kafka.consumer_lag",
      "service": "kafka"
    },
    {
      "query_id": "otel_collector.exporter_queue_saturation",
      "signal_id": "otel_collector_exporter_queue_saturation",
      "template_id": "otel.exporter_queue_saturation",
      "service": "otel-collector"
    },
    {
      "query_id": "valkey_cart.memory_used_bytes",
      "signal_id": "valkey_cart_memory_used_bytes",
      "template_id": "redis.memory_used_bytes",
      "service": "valkey-cart"
    }
