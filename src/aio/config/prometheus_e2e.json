{
  "schema_version": "1.0",
  "observation_queries": [
    {
      "query_id": "checkout.bad_ratio.24h",
      "signal_id": "checkout_bad_ratio_24h",
      "promql": "(sum(rate(traces_span_metrics_duration_milliseconds_count{service_name=\"checkout\",status_code=\"STATUS_CODE_ERROR\"}[24h])) or vector(0)) / clamp_min(sum(rate(traces_span_metrics_duration_milliseconds_count{service_name=\"checkout\"}[24h])), 0.000000001)",
      "unit": "ratio",
      "window": "24h",
      "labels": {}
    },
    {
      "query_id": "checkout.payment_error_rate.5m",
      "signal_id": "checkout_payment_error_rate_5m",
      "promql": "(sum(rate(traces_span_metrics_duration_milliseconds_count{service_name=\"checkout\",status_code=\"STATUS_CODE_ERROR\"}[5m])) or vector(0)) / clamp_min(sum(rate(traces_span_metrics_duration_milliseconds_count{service_name=\"checkout\"}[5m])), 0.000000001)",
      "unit": "ratio",
      "window": "5m",
      "labels": {
        "service": "checkout",
        "dependency": "payment"
      }
    }
  ],
  "metric_series_queries": [
