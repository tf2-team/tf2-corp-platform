        "owner": "catalog-oncall",
        "flow": "catalog",
        "dependencies": [
          "postgresql"
        ]
      },
      {
        "name": "product-reviews",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "catalog-oncall",
        "flow": "catalog",
        "dependencies": [
          "flagd"
        ]
      },
      {
        "name": "recommendation",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "recommendation-oncall",
        "flow": "recommendation",
        "dependencies": [
          "product-catalog",
          "flagd"
        ]
      },
      {
        "name": "cart",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": [
          "flagd",
          "valkey-cart"
        ]
      },
      {
        "name": "ad",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "platform-oncall",
        "flow": "platform",
        "dependencies": [
          "flagd"
        ]
      },
      {
        "name": "currency",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": []
      },
      {
        "name": "shipping",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": [
          "quote"
        ]
      },
      {
        "name": "email",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": []
      },
      {
        "name": "quote",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": []
      },
      {
        "name": "flagd",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "platform-oncall",
        "flow": "platform",
        "dependencies": []
      },
      {
        "name": "fraud-detection",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": [
          "flagd"
        ]
      },
      {
        "name": "load-generator",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "platform-oncall",
