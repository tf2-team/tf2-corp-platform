      {
        "name": "postgresql",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "data-platform-oncall",
        "flow": "data",
        "dependencies": []
      },
      {
        "name": "valkey-cart",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": []
      }
    ]
  },
  "prometheus_queries": {
    "prometheus.collection_health": "vector(1)",
    "checkout.bad_ratio.24h": "((sum(increase(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\",rpc_grpc_status_code!=\"0\"}[24h])) or on() (0 * sum(increase(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[24h])))) / clamp_min(sum(increase(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[24h])), 1)) and on() (sum(increase(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[24h])) > 0)",
    "checkout.burn_rate.fast": "clamp_max(((sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\",rpc_grpc_status_code!=\"0\"}[5m])) or on() (0 * sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[5m])))) / clamp_min(sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[5m])), 0.000001)), scalar(((sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\",rpc_grpc_status_code!=\"0\"}[1h])) or on() (0 * sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[1h])))) / clamp_min(sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[1h])), 0.000001)))) / 0.01",
    "checkout.burn_rate.slow": "clamp_max(((sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\",rpc_grpc_status_code!=\"0\"}[30m])) or on() (0 * sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[30m])))) / clamp_min(sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[30m])), 0.000001)), scalar(((sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\",rpc_grpc_status_code!=\"0\"}[6h])) or on() (0 * sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[6h])))) / clamp_min(sum(rate(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[6h])), 0.000001)))) / 0.01",
    "checkout.payment_error_rate.5m": "((sum(rate(traces_span_metrics_calls_total{service_name=\"checkout\",span_name=~\".*[Pp]ayment.*\",status_code=\"STATUS_CODE_ERROR\"}[5m])) or on() (0 * sum(rate(traces_span_metrics_calls_total{service_name=\"checkout\",span_name=~\".*[Pp]ayment.*\"}[5m])))) / clamp_min(sum(rate(traces_span_metrics_calls_total{service_name=\"checkout\",span_name=~\".*[Pp]ayment.*\"}[5m])), 0.000001)) and on() (sum(rate(traces_span_metrics_calls_total{service_name=\"checkout\",span_name=~\".*[Pp]ayment.*\"}[5m])) > 0)",
    "checkout.p95_latency.5m": "(histogram_quantile(0.95, sum(rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"checkout\"}[5m])) by (le, service_name)) / 1000) and on(service_name) (sum(rate(traces_span_metrics_duration_milliseconds_count{service_name=\"checkout\"}[5m])) by (service_name) > 0)",
    "product-catalog.cpu_millicores": "sum(k8s_pod_cpu_usage{k8s_deployment_name=\"product-catalog\"}) * 1000"
  },
  "prometheus_services": [
    "checkout",
    "payment",
    "cart",
    "product-catalog"
  ],
  "prometheus_metric_templates": {
    "p95_latency_5m": {
      "template": "(histogram_quantile(0.95, sum(rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"$service\"}[5m])) by (le, service_name)) / 1000) and on(service_name) (sum(rate(traces_span_metrics_duration_milliseconds_count{service_name=\"$service\"}[5m])) by (service_name) > 0)",
      "unit": "seconds",
      "window": "5m",
      "feature_role": "anomaly_input",
      "required_labels": []
    },
    "error_rate_5m": {
      "template": "((sum(rate(traces_span_metrics_calls_total{service_name=\"$service\",status_code=\"STATUS_CODE_ERROR\"}[5m])) or on() (0 * sum(rate(traces_span_metrics_calls_total{service_name=\"$service\"}[5m])))) / clamp_min(sum(rate(traces_span_metrics_calls_total{service_name=\"$service\"}[5m])), 0.000001)) and on() (sum(rate(traces_span_metrics_calls_total{service_name=\"$service\"}[5m])) > 0)",
      "unit": "ratio",
      "window": "5m",
      "feature_role": "anomaly_input",
      "required_labels": []
    },
    "request_rate_5m": {
      "template": "sum(rate(traces_span_metrics_calls_total{service_name=\"$service\"}[5m]))",
      "unit": "requests_per_second",
      "window": "5m",
      "feature_role": "anomaly_input",
      "required_labels": []
    },
    "cpu_millicores": {
      "template": "(sum(rate(container_cpu_usage_seconds_total{container=\"$service\"}[5m])) * 1000) or (sum(rate(container_cpu_usage_total{container_name=~\".*$service.*\"}[5m])) * 1000) or (sum(k8s_pod_cpu_usage{k8s_deployment_name=\"$service\"}) * 1000)",
      "unit": "count",
      "window": "5m",
      "feature_role": "anomaly_input",
      "required_labels": []
    }
  },
  "prometheus_metrics": [
    "p95_latency_5m",
    "error_rate_5m",
    "request_rate_5m",
    "cpu_millicores"
  ],
  "signals": [
    {
      "id": "prometheus_collection_health",
      "source": "prometheus",
      "query_id": "prometheus.collection_health",
      "unit": "count",
      "window": "instant",
      "flow": "monitoring",
      "service": "aiops",
      "feature_role": "diagnostic",
      "required_labels": []
    },
    {
      "id": "checkout_bad_ratio_24h",
      "source": "prometheus",
      "query_id": "checkout.bad_ratio.24h",
      "unit": "ratio",
      "window": "24h",
      "flow": "checkout",
      "service": "checkout",
      "feature_role": "official_slo",
      "required_labels": [],
      "labels": {
        "impact": "error_budget_burn"
      }
    },
    {
      "id": "checkout_payment_error_rate_5m",
      "source": "prometheus",
      "query_id": "checkout.payment_error_rate.5m",
      "unit": "ratio",
      "window": "5m",
      "flow": "checkout",
      "service": "checkout",
      "feature_role": "diagnostic",
      "required_labels": [
        "service",
        "dependency"
      ]
    },
    {
      "id": "checkout_burn_rate_fast",
      "source": "prometheus",
      "query_id": "checkout.burn_rate.fast",
      "unit": "count",
      "window": "5m/1h",
      "flow": "checkout",
      "service": "checkout",
      "feature_role": "official_slo",
      "required_labels": [],
      "labels": {
        "impact": "error_budget_burn"
      }
    },
    {
      "id": "checkout_burn_rate_slow",
      "source": "prometheus",
      "query_id": "checkout.burn_rate.slow",
      "unit": "count",
      "window": "30m/6h",
      "flow": "checkout",
      "service": "checkout",
      "feature_role": "official_slo",
      "required_labels": [],
      "labels": {
        "impact": "error_budget_burn"
      }
    },
    {
      "id": "checkout_p95_latency_5m",
      "source": "prometheus",
      "query_id": "checkout.p95_latency.5m",
      "unit": "seconds",
      "window": "5m",
      "flow": "checkout",
      "service": "checkout",
      "feature_role": "anomaly_input",
      "required_labels": []
    },
    {
      "id": "product_catalog_cpu_millicores",
      "source": "prometheus",
      "query_id": "product-catalog.cpu_millicores",
      "unit": "count",
      "window": "5m",
      "flow": "catalog",
      "service": "product-catalog",
      "feature_role": "anomaly_input",
      "required_labels": []
    }
  ],
  "detectors": [
    {
      "id": "ops01_checkout_slo",
      "type": "threshold",
      "enabled": true,
      "signal_id": "checkout_bad_ratio_24h",
      "flow": "checkout",
      "service": "checkout",
      "severity": "SEV1",
      "runbook_id": "RB-CHECKOUT-SLO"
    },
    {
      "id": "ops02_monitoring_loss",
      "type": "no-data",
      "enabled": true,
      "signal_ids": [
        "prometheus_collection_health"
      ],
      "flow": "monitoring",
      "service": "aiops",
      "severity": "SEV2",
      "runbook_id": "RB-MONITORING-LOSS"
    },
    {
      "id": "ops03_checkout_payment_dependency",
      "type": "dependency",
      "enabled": true,
      "signal_id": "checkout_payment_error_rate_5m",
      "flow": "checkout",
      "service": "checkout",
      "dependency": "payment",
      "severity": "SEV2",
      "runbook_id": "RB-CHECKOUT-DEPENDENCY"
    },
    {
      "id": "ops04_checkout_latency_p95",
      "type": "threshold",
      "enabled": true,
      "signal_id": "checkout_p95_latency_5m",
      "flow": "checkout",
      "service": "checkout",
      "severity": "SEV1",
      "runbook_id": "RB-CHECKOUT-LATENCY"
    },
    {
      "id": "ops05_cart_error_rate",
      "type": "threshold",
      "enabled": false,
      "signal_id": "cart_error_rate_5m",
      "flow": "checkout",
      "service": "cart",
      "severity": "SEV1",
      "runbook_id": "RB-CART-ERROR-RATE"
    },
    {
      "id": "ops06_product_catalog_cpu",
      "type": "threshold",
      "enabled": true,
      "signal_id": "product_catalog_cpu_millicores",
      "flow": "catalog",
      "service": "product-catalog",
      "severity": "SEV2",
      "runbook_id": "RB-PRODUCT-CATALOG-CPU"
    },
    {
      "id": "auto_checkout_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "checkout_error_rate_5m",
      "flow": "checkout",
      "service": "checkout",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_payment_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "payment_error_rate_5m",
      "flow": "checkout",
      "service": "payment",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_product_catalog_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "product_catalog_error_rate_5m",
      "flow": "catalog",
      "service": "product-catalog",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_cart_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "cart_error_rate_5m",
      "flow": "checkout",
      "service": "cart",
      "severity": "SEV2",
      "runbook_id": "RB-CART-ERROR-RATE"
    },
    {
      "id": "ops07_checkout_fast_burn",
      "type": "threshold",
      "enabled": true,
      "signal_id": "checkout_burn_rate_fast",
      "flow": "checkout",
      "service": "checkout",
      "severity": "SEV1",
      "runbook_id": "RB-CHECKOUT-SLO"
    },
    {
      "id": "ops08_checkout_slow_burn",
      "type": "threshold",
      "enabled": true,
      "signal_id": "checkout_burn_rate_slow",
      "flow": "checkout",
      "service": "checkout",
      "severity": "SEV2",
      "runbook_id": "RB-CHECKOUT-SLO"
    }
  ],
  "policy": {
    "protected_targets": [
      "aiops",
      "flagd",
      "jaeger",
      "load-generator",
      "postgresql"
    ],
    "stateful_kinds": [
      "StatefulSet",
      "Database"
    ],
    "non_actionable_flows": [
      "monitoring",
      "observability",
      "testing"
    ]
  },
  "rca": {
    "enabled": true
  }
}
