  "prometheus_queries": {
    "checkout.bad_ratio.24h": "(sum(increase(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\",rpc_grpc_status_code!=\"0\"}[24h])) / clamp_min(sum(increase(rpc_server_duration_milliseconds_count{service_name=\"checkout\",rpc_method=\"PlaceOrder\"}[24h])), 1)) or vector(0)",
    "checkout.payment_error_rate.5m": "(sum(rate(http_client_duration_milliseconds_count{service_name=\"checkout\",server_address=~\"payment.*\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_client_duration_milliseconds_count{service_name=\"checkout\",server_address=~\"payment.*\"}[5m])), 1)) or vector(0)",
    "checkout.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"checkout\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"checkout\"}[5m])), 1)) or vector(0)",
    "payment.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"payment\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"payment\"}[5m])), 1)) or vector(0)",
    "frontend-proxy.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"frontend-proxy\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"frontend-proxy\"}[5m])), 1)) or vector(0)",
    "frontend.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"frontend\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"frontend\"}[5m])), 1)) or vector(0)",
    "product-catalog.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"product-catalog\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"product-catalog\"}[5m])), 1)) or vector(0)",
    "product-reviews.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"product-reviews\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"product-reviews\"}[5m])), 1)) or vector(0)",
    "recommendation.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"recommendation\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"recommendation\"}[5m])), 1)) or vector(0)",
    "cart.error_rate.5m": "((sum(rate(http_server_request_duration_seconds_count{service_name=\"cart\",http_response_status_code=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"cart\"}[5m])), 0.000000001))",
    "ad.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"ad\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"ad\"}[5m])), 1)) or vector(0)",
    "currency.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"currency\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"currency\"}[5m])), 1)) or vector(0)",
    "shipping.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"shipping\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"shipping\"}[5m])), 1)) or vector(0)",
    "email.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"email\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"email\"}[5m])), 1)) or vector(0)",
    "quote.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"quote\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"quote\"}[5m])), 1)) or vector(0)",
    "flagd.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"flagd\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"flagd\"}[5m])), 1)) or vector(0)",
    "fraud-detection.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"fraud-detection\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"fraud-detection\"}[5m])), 1)) or vector(0)",
    "load-generator.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"load-generator\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"load-generator\"}[5m])), 1)) or vector(0)",
    "jaeger.error_rate.5m": "(sum(rate(http_server_duration_milliseconds_count{service_name=\"jaeger\",http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=\"jaeger\"}[5m])), 1)) or vector(0)",
    "checkout.p95_latency.5m": "histogram_quantile(0.95, sum(rate(rpc_server_duration_milliseconds_bucket{service_name=\"checkout\"}[5m])) by (le))",
    "product-catalog.cpu_millicores": "sum(k8s_pod_cpu_usage{k8s_deployment_name=\"product-catalog\"})"
  },
