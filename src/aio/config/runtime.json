        "dependencies": [
          "frontend-proxy",
          "flagd"
        ]
      },
      {
        "name": "jaeger",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "platform-oncall",
        "flow": "observability",
        "dependencies": []
