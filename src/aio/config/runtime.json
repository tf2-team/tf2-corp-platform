          "jaeger"
        ]
      },
      {
        "name": "frontend",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "frontend-oncall",
        "flow": "web",
        "dependencies": [
          "product-catalog",
          "product-reviews",
          "recommendation",
          "checkout",
          "cart",
          "ad"
        ]
