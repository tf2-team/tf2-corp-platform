        "flow": "checkout",
        "dependencies": [
          "cart",
          "currency",
          "product-catalog",
          "shipping",
          "payment",
          "email"
        ]
      },
      {
        "name": "payment",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "payments-oncall",
        "flow": "checkout",
        "dependencies": []
      },
      {
        "name": "frontend-proxy",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "platform-oncall",
        "flow": "edge",
