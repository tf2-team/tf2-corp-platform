{
  "schema_version": "1.0",
  "environment": "techx-corp-prod",
  "topology": {
    "services": [
      {
        "name": "checkout",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": [
          "cart",
          "currency",
          "product-catalog",
          "shipping",
          "payment",
          "email",
          "kafka"
        ]
      },
      {
        "name": "payment",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "payments-oncall",
        "flow": "checkout",
        "dependencies": []
      },
      {
        "name": "frontend-proxy",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "platform-oncall",
        "flow": "edge",
        "dependencies": [
          "frontend",
          "jaeger"
        ]
      },
      {
        "name": "frontend",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "frontend-oncall",
        "flow": "web",
        "dependencies": [
          "product-catalog",
          "product-reviews",
          "recommendation",
          "checkout",
          "cart",
          "ad"
        ]
      },
      {
        "name": "product-catalog",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "catalog-oncall",
        "flow": "catalog",
        "dependencies": [
          "postgresql"
        ]
      },
      {
        "name": "product-reviews",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "catalog-oncall",
        "flow": "catalog",
        "dependencies": [
          "product-catalog",
          "flagd"
        ]
      },
      {
        "name": "recommendation",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "recommendation-oncall",
        "flow": "recommendation",
        "dependencies": [
          "product-catalog",
          "flagd"
        ]
      },
      {
        "name": "cart",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": [
          "flagd",
          "valkey-cart"
        ]
      },
      {
        "name": "ad",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "platform-oncall",
        "flow": "platform",
        "dependencies": [
          "flagd"
        ]
      },
      {
        "name": "currency",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": []
      },
      {
        "name": "shipping",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": [
          "quote"
        ]
      },
      {
        "name": "email",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": []
      },
      {
        "name": "quote",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": []
      },
      {
        "name": "flagd",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "platform-oncall",
        "flow": "platform",
        "dependencies": []
      },
      {
        "name": "fraud-detection",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": [
          "flagd"
        ]
      },
      {
        "name": "load-generator",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "platform-oncall",
        "flow": "testing",
        "dependencies": [
          "frontend-proxy",
          "flagd"
        ]
      },
      {
        "name": "jaeger",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "platform-oncall",
        "flow": "observability",
        "dependencies": []
      },
      {
        "name": "otel-collector",
        "namespace": "techx-corp-prod",
        "kind": "Deployment",
        "owner": "platform-oncall",
        "flow": "observability",
        "dependencies": []
      },
      {
        "name": "kafka",
        "namespace": "external",
        "kind": "StatefulSet",
        "owner": "platform-oncall",
        "flow": "platform",
        "dependencies": []
      },
      {
        "name": "postgresql",
        "namespace": "external",
        "kind": "Database",
        "owner": "data-platform-oncall",
        "flow": "data",
        "dependencies": []
      },
      {
        "name": "valkey-cart",
        "namespace": "external",
        "kind": "Database",
        "owner": "checkout-oncall",
        "flow": "checkout",
        "dependencies": []
      },
      {
        "name": "opensearch",
        "namespace": "techx-corp-prod",
        "kind": "StatefulSet",
        "owner": "platform-oncall",
        "flow": "observability",
        "dependencies": []
      }
    ]
  },
  "signals": [],
  "detectors": [
    {
      "id": "ops02_monitoring_loss",
      "type": "no-data",
      "enabled": true,
      "signal_ids": [
        "__all_prometheus__"
      ],
      "flow": "monitoring",
      "service": "aiops",
      "severity": "SEV2",
      "runbook_id": "RB-MONITORING-LOSS"
    },
    {
      "id": "ops03_checkout_payment_dependency",
      "type": "dependency",
      "enabled": true,
      "signal_id": "checkout_payment_error_rate_5m",
      "flow": "checkout",
      "service": "checkout",
      "dependency": "payment",
      "severity": "SEV2",
      "runbook_id": "RB-CHECKOUT-DEPENDENCY"
    },
    {
      "id": "ops04_checkout_latency_p95",
      "type": "threshold",
      "enabled": true,
      "signal_id": "checkout_p95_latency_5m",
      "flow": "checkout",
      "service": "checkout",
      "severity": "SEV1",
      "runbook_id": "RB-CHECKOUT-LATENCY"
    },
    {
      "id": "ops05_cart_error_rate",
      "type": "threshold",
      "enabled": false,
      "signal_id": "cart_error_rate_5m",
      "flow": "checkout",
      "service": "cart",
      "severity": "SEV1",
      "runbook_id": "RB-CART-ERROR-RATE"
    },
    {
      "id": "ops06_product_catalog_cpu",
      "type": "threshold",
      "enabled": false,
      "signal_id": "product_catalog_cpu_millicores",
      "flow": "catalog",
      "service": "product-catalog",
      "severity": "SEV2",
      "runbook_id": "RB-PRODUCT-CATALOG-CPU"
    },
    {
      "id": "auto_checkout_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "checkout_error_rate_5m",
      "flow": "checkout",
      "service": "checkout",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_payment_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "payment_error_rate_5m",
      "flow": "checkout",
      "service": "payment",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_frontend_proxy_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "frontend_proxy_error_rate_5m",
      "flow": "edge",
      "service": "frontend-proxy",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_frontend_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "frontend_error_rate_5m",
      "flow": "web",
      "service": "frontend",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_product_catalog_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "product_catalog_error_rate_5m",
      "flow": "catalog",
      "service": "product-catalog",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_product_reviews_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "product_reviews_error_rate_5m",
      "flow": "catalog",
      "service": "product-reviews",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_recommendation_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "recommendation_error_rate_5m",
      "flow": "recommendation",
      "service": "recommendation",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_cart_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "cart_error_rate_5m",
      "flow": "checkout",
      "service": "cart",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_ad_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "ad_error_rate_5m",
      "flow": "platform",
      "service": "ad",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_currency_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "currency_error_rate_5m",
      "flow": "checkout",
      "service": "currency",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_shipping_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "shipping_error_rate_5m",
      "flow": "checkout",
      "service": "shipping",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_email_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "email_error_rate_5m",
      "flow": "checkout",
      "service": "email",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_quote_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "quote_error_rate_5m",
      "flow": "checkout",
      "service": "quote",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    },
    {
      "id": "auto_fraud_detection_error_rate",
      "type": "threshold",
      "enabled": true,
      "signal_id": "fraud_detection_error_rate_5m",
      "flow": "checkout",
      "service": "fraud-detection",
      "severity": "SEV2",
      "runbook_id": "RB-SERVICE-ERROR-RATE"
    }
  ],
  "policy": {
    "protected_targets": [
      "aiops",
      "flagd",
      "jaeger",
      "load-generator",
      "postgresql",
      "valkey-cart",
      "opensearch"
    ],
    "stateful_kinds": [
      "StatefulSet",
      "Database"
    ],
    "non_actionable_flows": [
      "monitoring",
      "observability",
      "testing"
    ]
  },
  "rca": {
    "enabled": true
  }
}
