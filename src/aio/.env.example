# Copy this non-secret template to .env and fill in local integration values.
# Never commit .env or put decoded Kubernetes Secret values in tracked files.

# Runtime
AIOPS_APP_TITLE=AIOps Runtime
AIOPS_API_HEALTH_LIVE_PATH=/health/live
AIOPS_API_PIPELINE_RUN_PATH=/api/v1/pipeline/run
AIOPS_HEALTH_STATUS=ok
AIOPS_ENVIRONMENT=techx-corp-prod
AIOPS_POLICY_MODE=dry-run
AIOPS_EVIDENCE_DIR=evidence
AIOPS_STATE_STORE_PATH=state/aiops.sqlite3
AIOPS_RUNTIME_CONFIG_PATH=config/runtime.json
AIOPS_HYPERPARAMETERS_PATH=config/hyperparameters.json
AIOPS_ACTIONS_CATALOG_PATH=config/actions.json
AIOPS_INCIDENTS_HISTORY_PATH=config/incidents_history.json
AIOPS_REMEDIATION_AUDIT_PATH=state/remediation_audit.jsonl
AIOPS_RCA_HISTORY_PATH=state/rca_history.jsonl
AIOPS_QUALIFICATION_GATE_DEV=false
AIOPS_QUALIFICATION_SCHEMA_PATH=config/signal_qualification_schema.json
AIOPS_NORMALIZATION_SCHEMA_PATH=config/signal_normalization_schema.json
AIOPS_QUALIFICATION_MAX_SAMPLE_AGE_SECONDS=300
AIOPS_AUTO_RUN_ENABLED=true
AIOPS_AUTO_RUN_INTERVAL_SECONDS=5
AIOPS_ACTION_TYPE_RESTART=restart
AIOPS_ACTION_TARGET_KIND_DEPLOYMENT=Deployment
AIOPS_DEFAULT_ACTION_REPLICAS=3

# Prometheus through kubectl port-forward svc/prometheus 9090:9090
AIOPS_PROMETHEUS_BASE_URL=http://localhost:9090
AIOPS_PROMETHEUS_TIMEOUT_SECONDS=30
AIOPS_PROMETHEUS_TOKEN=
AIOPS_PROMETHEUS_ACCOUNT=prometheus-local

# Shared secret is local/test data until the Grafana contact point is provisioned.
AIOPS_GRAFANA_WEBHOOK_SECRET=CHANGE_ME_LOCAL_SHARED_SECRET

# Jaeger query API uses the configured /jaeger/ui base path.
AIOPS_JAEGER_BASE_URL=http://localhost:16686/jaeger/ui
AIOPS_JAEGER_TOKEN=
AIOPS_JAEGER_ACCOUNT=jaeger-local

# OpenSearch is HTTPS and requires Basic Auth even through port-forward.
AIOPS_OPENSEARCH_BASE_URL=https://localhost:9200
AIOPS_OPENSEARCH_USERNAME=CHANGE_ME_OPENSEARCH_USERNAME
AIOPS_OPENSEARCH_PASSWORD=CHANGE_ME_OPENSEARCH_PASSWORD
AIOPS_OPENSEARCH_ACCOUNT=opensearch-local
AIOPS_OPENSEARCH_VERIFY_TLS=false

# Dev escape hatch for local pipeline checks with synthetic/partial signals.
AIOPS_QUALIFICATION_GATE_DEV=false
AIOPS_AUTO_RUN_INTERVAL_SECONDS=5

# kubectl proxy authenticates with the active kubeconfig context.
AIOPS_KUBERNETES_API_URL=http://localhost:8001
AIOPS_KUBERNETES_BEARER_TOKEN=
AIOPS_KUBERNETES_ACCOUNT=techx-corp-prod

# Set this to the Grafana OnCall/inbound webhook URL when Grafana should fan out
# to its configured contact points. Provider grafana uses the same JSON payload
# as generic; auto still detects Discord webhook URLs.
AIOPS_NOTIFICATION_WEBHOOK_URL=https://webhook.site/<FILL_IN_YOUR_UUID>
AIOPS_NOTIFICATION_TOKEN=
AIOPS_NOTIFICATION_ACCOUNT=notification-test
AIOPS_NOTIFICATION_PROVIDER=auto

# Smoke-test-only values (ignored by Settings because extra fields are allowed).
AIOPS_SMOKE_NAMESPACE=techx-corp-prod
AIOPS_SMOKE_DEPLOYMENT=checkout
AIOPS_SMOKE_GRAFANA_BASE_URL=http://localhost:3000
AIOPS_SMOKE_AIOPS_BASE_URL=http://localhost:8000
AIOPS_SMOKE_OPENSEARCH_INDICES=otel-logs-*,otel-v1-apm-span-*

# Optional platform integrations
AIOPS_AIE_STATUS_URL=https://aie.example
AIOPS_AIE_TOKEN=CHANGE_ME_AIE_TOKEN
AIOPS_AIE_ACCOUNT=CHANGE_ME_AIE_ACCOUNT
AIOPS_CDO_COST_URL=https://cost.example
AIOPS_CDO_COST_TOKEN=CHANGE_ME_CDO_COST_TOKEN
AIOPS_CDO_COST_ACCOUNT=CHANGE_ME_CDO_COST_ACCOUNT
AIOPS_LIVE_EXECUTOR_URL=https://live-executor.example
AIOPS_LIVE_EXECUTOR_TOKEN=CHANGE_ME_LIVE_EXECUTOR_TOKEN
AIOPS_LIVE_EXECUTOR_ACCOUNT=CHANGE_ME_LIVE_EXECUTOR_ACCOUNT

# Logging format:
# pretty = full multi-line format
# plain  = original single-line format
AIOPS_LOG_FORMAT=pretty
AIOPS_LOG_LEVEL=INFO